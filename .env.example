# Knowledge Bank — environment example
# Replit provisions DATABASE_URL automatically when the PG database is created.
DATABASE_URL=postgres://user:pass@localhost:5432/knowledge_bank

# API server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Sessions (cookie-based, stored in Postgres via connect-pg-simple)
SESSION_SECRET=change-me-please-32+chars

# Signed URLs for preview/download tokens
SIGNED_URL_SECRET=change-me-please-32+chars
SIGNED_URL_TTL_SECONDS=300

# Uploads
MAX_UPLOAD_MB=50
ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain,text/markdown,text/csv,image/png,image/jpeg,application/zip

# Storage (local for dev; s3 stub available)
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=.data/storage

# CORS origin for the web client (leave blank to allow same-origin)
WEB_ORIGIN=

# Web app build-time configuration (read at vite build time)
# Base URL the web app calls. If the API is on a different host/port than the
# web app, set this to the API origin (no trailing slash). Leave blank when
# the web and API share an origin and the web is reverse-proxied at /api.
VITE_API_BASE=http://localhost:8080

# Upload size limit the web shows in its inline validation. Should mirror the
# server-side MAX_UPLOAD_MB so the UI rejects oversized files before bothering
# the network. The server is still the authoritative check.
VITE_MAX_UPLOAD_MB=50
