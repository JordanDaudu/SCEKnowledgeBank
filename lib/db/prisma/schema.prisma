// Knowledge Bank — Prisma schema.
//
// 1:1 mirror of the previous Drizzle schema (see git history for
// `lib/db/src/schema/*.ts`). This task is a behaviour-preserving ORM swap —
// no new columns, no new tables. Sprint-2 feature additions live in
// follow-up tasks.
//
// Indexes that Prisma cannot express directly — the partial unique on
// `users.email`, the partial `documents_deleted_at_idx`, and the
// `gin_trgm_ops` indexes on documents — are added in the init migration's
// raw SQL section (see `prisma/migrations/0_init/migration.sql`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity ─────────────────────────────────────────────────────

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  primaryFor      User[]           @relation("UserPrimaryRole")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([name], map: "roles_name_unique")
  @@map("roles")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String
  passwordHash  String    @map("password_hash")
  displayName   String    @map("display_name")
  primaryRoleId String?   @map("primary_role_id") @db.Uuid
  isActive      Boolean   @default(true) @map("is_active")
  // Lifecycle status independent of soft-delete (`deletedAt`) and the
  // legacy `isActive` flag. `ACTIVE` users can log in normally;
  // `PENDING_APPROVAL` users (lecturers awaiting admin sign-off) are
  // rejected at login with a clean message; `DISABLED` users are
  // blocked entirely. Defaults to ACTIVE so existing seed data keeps
  // working without backfill.
  status        String    @default("ACTIVE")
  studentId     String?   @map("student_id")
  lecturerId    String?   @map("lecturer_id")
  department    String?
  // Profile foundation: a unique handle (canonical-lowercase) distinct from
  // displayName, plus the stored avatar. Case-insensitive uniqueness +
  // soft-delete-aware partial unique index live in raw SQL (see migration),
  // mirroring the email index — Prisma can't express partial unique indexes.
  username          String?   @map("username")
  avatarStoragePath String?   @map("avatar_storage_path")
  avatarMimeType    String?   @map("avatar_mime_type")
  // Storage quota — usedBytes is the running sum of stored file bytes,
  // maintained transactionally with each upload / hard-delete. quotaBytes
  // is a per-user override; when NULL the server default
  // (`DEFAULT_USER_STORAGE_QUOTA_MB`) is used.
  usedBytes     BigInt    @default(0) @map("used_bytes")
  quotaBytes    BigInt?   @map("quota_bytes")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()
  // Set when a soft-deleted account is permanently removed (PII scrubbed).
  // The row + ownership FKs are kept; this blocks restore.
  anonymizedAt  DateTime? @map("anonymized_at") @db.Timestamptz()

  primaryRole       Role?                 @relation("UserPrimaryRole", fields: [primaryRoleId], references: [id], onDelete: SetNull)
  userRoles         UserRole[]
  documentsUploaded Document[]            @relation("DocumentUploader")
  documentsOwned    Document[]            @relation("DocumentOwner")
  documentsCreated  Document[]            @relation("DocumentCreator")
  documentsUpdated  Document[]            @relation("DocumentUpdater")
  documentsReviewed Document[]            @relation("DocumentReviewer")
  documentFilesUploaded DocumentFile[]    @relation("DocumentFileUploadedBy")
  coursesLectured   Course[]
  comments          Comment[]
  commentMentions   CommentMention[]      @relation("CommentMentionUser")
  materialRequests  MaterialRequest[]
  requestVotes      RequestVote[]
  viewHistory       MaterialViewHistory[]
  auditLogs         AuditLog[]
  courseEnrollments CourseEnrollment[]
  notificationsReceived Notification[]    @relation("NotificationRecipient")
  notificationsActed    Notification[]    @relation("NotificationActor")
  commentReactions      CommentReaction[] @relation("CommentReactionUser")
  documentFavorites     DocumentFavorite[]
  studyCollections      StudyCollection[]
  collectionFollows     StudyCollectionFollower[]
  studyProgress         StudyProgress[]
  collectionLikes    StudyCollectionLike[]
  collectionRatings  StudyCollectionRating[]
  collectionViews    StudyCollectionView[]
  collectionComments StudyCollectionComment[]
  badges             UserBadge[]

  @@index([primaryRoleId], map: "users_primary_role_idx")
  @@map("users")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId], map: "user_roles_role_idx")
  @@map("user_roles")
}

// Earned gamification achievements. Definitions live in code
// (`api-server/src/lib/reputation.ts`); only the awarded rows are stored.
// Permanent once earned — the unique key makes awarding idempotent.
model UserBadge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  badgeKey  String   @map("badge_key")
  awardedAt DateTime @default(now()) @map("awarded_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey], map: "user_badges_user_key_unique")
  @@index([userId], map: "user_badges_user_idx")
  @@map("user_badges")
}

model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String
  description String?

  rolePermissions RolePermission[]

  @@unique([key], map: "permissions_key_unique")
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Taxonomy ─────────────────────────────────────────────────────

model Course {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String
  title          String
  lecturerName   String   @map("lecturer_name")
  lecturerUserId String?  @map("lecturer_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  lecturer    User?              @relation(fields: [lecturerUserId], references: [id], onDelete: SetNull)
  documents   Document[]
  requests    MaterialRequest[]
  enrollments CourseEnrollment[]
  studyCollections StudyCollection[]

  @@unique([code], map: "courses_code_unique")
  @@index([lecturerName], map: "courses_lecturer_name_idx")
  @@map("courses")
}

model CourseEnrollment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  roleInCourse String   @map("role_in_course")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId], map: "course_enrollments_user_course_unique")
  @@index([courseId], map: "course_enrollments_course_idx")
  @@map("course_enrollments")
}

model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  documents        Document[]
  studyCollections StudyCollection[]

  @@unique([name], map: "categories_name_unique")
  @@unique([slug], map: "categories_slug_unique")
  @@map("categories")
}

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  documents           DocumentTag[]
  studyCollectionTags StudyCollectionTag[]

  @@unique([name], map: "tags_name_unique")
  @@map("tags")
}

// ─── Documents ────────────────────────────────────────────────────

model Document {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  description      String    @default("")
  courseId         String?   @map("course_id") @db.Uuid
  categoryId       String?   @map("category_id") @db.Uuid
  materialType     String    @default("other") @map("material_type")
  semester         String?
  academicYear     Int?      @map("academic_year")
  visibility       String    @default("public")
  status           String    @default("published")
  uploaderId       String    @map("uploader_id") @db.Uuid
  ownerId          String    @map("owner_id") @db.Uuid
  currentVersion   Int       @default(1) @map("current_version")
  isLatestVersion  Boolean   @default(true) @map("is_latest_version")
  // No FK in the previous Drizzle schema either; preserved as-is.
  parentDocumentId String?   @map("parent_document_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz()
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid

  // ─── Review / approval workflow (Sprint-3 M2) ─────────────────
  // Status values used by the workflow (additive to the existing
  // `draft|published|archived` set): `pending_review`, `approved`,
  // `rejected`. Transitions:
  //   draft|rejected → pending_review  (submitForReview)
  //   pending_review → approved|rejected  (approve / reject)
  // `reviewedBy` / `reviewedAt` are stamped by approve+reject.
  // `reviewReason` is the rejection rationale (cleared on approve).
  // `submittedForReviewAt` records the most recent submission, so
  // reviewer queues can order by oldest-first.
  reviewedBy            String?   @map("reviewed_by") @db.Uuid
  reviewedAt            DateTime? @map("reviewed_at") @db.Timestamptz()
  reviewReason          String?   @map("review_reason")
  submittedForReviewAt  DateTime? @map("submitted_for_review_at") @db.Timestamptz()

  // ─── Engagement counters (Refinement Phase 2: ranking) ────────
  // Denormalised counts maintained incrementally (O(1) per event) so
  // ranking/sorting never needs a per-request GROUP BY over the event
  // tables. Backfilled from material_view_history / audit_logs
  // (document.download) / document_favorites in migration
  // 20260528100000. Treat as best-effort hints, not authoritative.
  viewCount       Int @default(0) @map("view_count")
  downloadCount   Int @default(0) @map("download_count")
  favoriteCount   Int @default(0) @map("favorite_count")

  // ─── AI suggestions (design 2026-06-10) ───────────────────────
  // Uploader-accepted AI-generated summary. Empty string = none.
  // Never auto-populated; only written when the owner accepts a
  // pending DocumentAiSuggestion. Distinct from `description`,
  // which is always human-authored.
  aiSummary String @default("") @map("ai_summary")

  course            Course?               @relation(fields: [courseId], references: [id], onDelete: SetNull)
  category          Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  uploader          User                  @relation("DocumentUploader", fields: [uploaderId], references: [id], onDelete: Restrict)
  owner             User                  @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  creator           User?                 @relation("DocumentCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater           User?                 @relation("DocumentUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  reviewer          User?                 @relation("DocumentReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  files             DocumentFile[]
  tags              DocumentTag[]
  comments          Comment[]
  views             MaterialViewHistory[]
  requestsFulfilled MaterialRequest[]     @relation("FulfillingDocument")
  favorites         DocumentFavorite[]
  collectionItems   StudyCollectionItem[]
  studyProgress     StudyProgress[]
  aiSuggestion      DocumentAiSuggestion?

  @@index([courseId], map: "documents_course_idx")
  @@index([categoryId], map: "documents_category_idx")
  @@index([materialType], map: "documents_material_type_idx")
  @@index([semester, academicYear], map: "documents_semester_year_idx")
  @@index([uploaderId], map: "documents_uploader_idx")
  @@index([createdAt], map: "documents_created_at_idx")
  @@index([viewCount], map: "documents_view_count_idx")
  @@index([downloadCount], map: "documents_download_count_idx")
  @@index([favoriteCount], map: "documents_favorite_count_idx")
  // Review queue: list pending_review docs (optionally scoped by
  // course for lecturers) ordered oldest-first.
  @@index([status, courseId, submittedForReviewAt], map: "documents_status_course_submitted_idx")
  @@map("documents")
}

model DocumentFile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId       String   @map("document_id") @db.Uuid
  originalFilename String   @map("original_filename")
  displayFilename  String   @map("display_filename")
  storedFilename   String   @map("stored_filename")
  mimeType         String   @map("mime_type")
  sizeBytes        BigInt   @map("size_bytes")
  storagePath      String   @map("storage_path")
  storageDriver    String   @default("local") @map("storage_driver")
  checksum         String
  versionLabel     String?  @map("version_label")
  uploadedAt       DateTime @default(now()) @map("uploaded_at") @db.Timestamptz()

  // ─── Versioning (US-5) ─────────────────────────────────────────
  // Each DocumentFile row is a linear version of its parent Document.
  // `versionNumber` is monotonically assigned per document (1, 2, 3…).
  // `changeNote` is the optional uploader note ("Fixed typos on p.4").
  // `uploadedById` records who uploaded this revision; nullable so
  // historical rows backfilled from the pre-versioning era stay valid.
  // TODO(sprint-3): richer diff/compare UI, branching versions,
  // ETag-style content-addressed dedup across versions.
  versionNumber     Int      @default(1) @map("version_number")
  changeNote        String?  @map("change_note")
  uploadedById      String?  @map("uploaded_by_id") @db.Uuid
  // Was this row billed against the uploader's quota at insert time?
  // `false` is set by restoreVersion (it reuses an existing
  // storage_path / blob, so we must not re-bill). Used by
  // softDeleteDocumentAndReleaseQuota to release the right amount.
  countedTowardQuota Boolean @default(true) @map("counted_toward_quota")

  // ─── Extracted metadata (Sprint 2, task #27) ──────────────────
  // Populated server-side on upload by `metadata.service.ts`. All
  // fields are nullable: extraction failure or unsupported file types
  // leave them NULL and the API falls back to a generic icon.
  extractedText     String? @map("extracted_text")
  pageCount         Int?    @map("page_count")
  detectedTitle     String? @map("detected_title")
  author            String?
  imageWidth        Int?    @map("image_width")
  imageHeight       Int?    @map("image_height")
  thumbnailPath     String? @map("thumbnail_path")
  thumbnailMimeType String? @map("thumbnail_mime_type")

  // ─── Smart metadata (Sprint-3 M4) ─────────────────────────────
  // Best-effort post-processors derived from `extractedText`:
  //   • language — ISO-639-1 short code (en/es/fr/de/...). NULL when
  //     the classifier could not reach the confidence threshold.
  //   • keywords — top tokens by frequency after stopword/length
  //     filtering. Empty array means no extracted text or every
  //     candidate was filtered out.
  language String?
  keywords String[] @default([])

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation("DocumentFileUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([documentId], map: "document_files_document_idx")
  @@index([checksum], map: "document_files_checksum_idx")
  @@index([documentId, versionNumber(sort: Desc)], map: "document_files_document_version_idx")
  @@map("document_files")
}

model DocumentTag {
  documentId String @map("document_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId], map: "document_tags_tag_idx")
  @@map("document_tags")
}

// AI-generated summary + tag suggestions awaiting uploader review
// (design 2026-06-10). One live row per document (`documentId` unique);
// regeneration overwrites in place. `suggestedTagIds` reference Tag rows
// validated at generation time. Status: pending | accepted | dismissed
// | failed.
model DocumentAiSuggestion {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId      String    @unique(map: "document_ai_suggestions_document_unique") @map("document_id") @db.Uuid
  summary         String    @default("")
  suggestedTagIds String[]  @default([]) @map("suggested_tag_ids") @db.Uuid
  status          String    @default("pending")
  error           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz()

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_ai_suggestions")
}

model MaterialViewHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  viewedAt   DateTime @default(now()) @map("viewed_at") @db.Timestamptz()

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt], map: "material_view_history_user_viewed_idx")
  @@index([documentId], map: "material_view_history_document_idx")
  @@map("material_view_history")
}

// ─── Comments ─────────────────────────────────────────────────────

model Comment {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String    @map("document_id") @db.Uuid
  authorId   String    @map("author_id") @db.Uuid
  // No FK in the previous Drizzle schema either; preserved as-is.
  parentId   String?   @map("parent_id") @db.Uuid
  body       String
  pageNumber Int?      @map("page_number")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz()

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  mentions CommentMention[]
  reactions CommentReaction[]

  @@index([documentId, createdAt], map: "comments_document_created_idx")
  @@index([parentId], map: "comments_parent_idx")
  @@index([authorId], map: "comments_author_idx")
  @@map("comments")
}

// ─── Reactions (Sprint-3 M6) ──────────────────────────────────────
// One row per (comment, user, kind). The unique key keeps a user from
// stacking the same kind on the same comment; different kinds are
// allowed (a user can react ":like" and ":thanks" to the same comment).

model CommentReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  kind      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation("CommentReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, kind], map: "comment_reactions_comment_user_kind_unique")
  @@index([commentId], map: "comment_reactions_comment_idx")
  @@index([userId], map: "comment_reactions_user_idx")
  @@map("comment_reactions")
}

// ─── Favorites (Sprint-3 M6) ──────────────────────────────────────
// User-scoped per-document subscription. Doubles as the "Following"
// list and as the notification subscription set for document activity
// (new comments, etc.).

model DocumentFavorite {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId], map: "document_favorites_user_document_unique")
  @@index([documentId], map: "document_favorites_document_idx")
  @@index([userId, createdAt(sort: Desc)], map: "document_favorites_user_created_idx")
  @@map("document_favorites")
}

model CommentMention {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId        String   @map("comment_id") @db.Uuid
  mentionedUserId  String   @map("mentioned_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  comment         Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser   User    @relation("CommentMentionUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId], map: "comment_mentions_comment_user_unique")
  @@index([mentionedUserId], map: "comment_mentions_user_idx")
  @@map("comment_mentions")
}

// ─── Requests ─────────────────────────────────────────────────────

model MaterialRequest {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                String
  description          String    @default("")
  courseId             String?   @map("course_id") @db.Uuid
  requestedBy          String    @map("requested_by") @db.Uuid
  status               String    @default("open")
  fulfillingDocumentId String?   @map("fulfilling_document_id") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz()

  course             Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  requester          User          @relation(fields: [requestedBy], references: [id], onDelete: Restrict)
  fulfillingDocument Document?     @relation("FulfillingDocument", fields: [fulfillingDocumentId], references: [id], onDelete: SetNull)
  votes              RequestVote[]

  @@index([status, createdAt], map: "material_requests_status_created_idx")
  @@index([courseId], map: "material_requests_course_idx")
  @@map("material_requests")
}

model RequestVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId String   @map("request_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  request MaterialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, requestId], map: "request_votes_user_request_unique")
  @@index([requestId], map: "request_votes_request_idx")
  @@map("request_votes")
}

// ─── Audit ────────────────────────────────────────────────────────

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt], map: "audit_logs_entity_idx")
  @@index([actorUserId], map: "audit_logs_actor_idx")
  @@map("audit_logs")
}

// ─── Notifications (Sprint-3 M1) ──────────────────────────────────
//
// Polling-only in-app notification bus. Producers (comment mentions,
// replies, future approvals/follows) call `notify(...)` which inserts
// here; the unique key (recipient_id, type, subject_type, subject_id)
// dedupes so the same producer event cannot create two rows for the
// same recipient.

model Notification {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientId String    @map("recipient_id") @db.Uuid
  // Optional — system-generated notifications have no actor.
  actorId     String?   @map("actor_id") @db.Uuid
  // Producer-defined kind, e.g. `comment.mention`, `comment.reply`.
  type        String
  // What the notification refers to. Stored as text (not uuid) so
  // non-uuid subjects (composite keys, future external refs) work
  // without a schema change.
  subjectType String    @map("subject_type")
  subjectId   String    @map("subject_id")
  body        String    @default("")
  // Optional deep-link path within the web app (e.g.
  // `/documents/<id>#comment-<cid>`).
  url         String?
  readAt      DateTime? @map("read_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  // Per-(recipient, type, subject) dedup: the same producer event
  // cannot create two rows for the same recipient on the same
  // subject. `type` is part of the key so that distinct review
  // outcomes on a single document (e.g. `document.rejected` then,
  // after a resubmit, `document.approved`) both reach the uploader —
  // a type-less key would silently suppress the second.
  // Cross-type collisions on the same subject (e.g. mention vs reply
  // on the same comment) stay the producer's responsibility: the
  // comment producer enforces type precedence (reply > mention)
  // before calling `notify(...)`.
  @@unique([recipientId, type, subjectType, subjectId], map: "notifications_recipient_type_subject_unique")
  // Two complementary indexes:
  //   • `_unread_idx` keeps `read_at` in the middle so the
  //     unread-count + unread-only feed (`WHERE recipient_id = ?
  //     AND read_at IS NULL ORDER BY created_at DESC`) is a clean
  //     index scan.
  //   • `_feed_idx` covers the default list query (no read_at
  //     predicate, just `WHERE recipient_id = ? ORDER BY
  //     created_at DESC LIMIT N`) without an extra sort step.
  @@index([recipientId, readAt, createdAt(sort: Desc)], map: "notifications_recipient_unread_idx")
  @@index([recipientId, createdAt(sort: Desc)], map: "notifications_recipient_feed_idx")
  @@map("notifications")
}

// ─── Sessions (connect-pg-simple shape) ───────────────────────────

model Session {
  sid    String   @id
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "session_expire_idx")
  @@map("session")
}

// ─── Prep Hub: study collections & progress (Refinement Phase 6) ───
//
// A collection is a user-owned (or, for learning paths, lecturer/admin
// curated) ordered grouping of existing documents. Items only reference
// documents by FK — no document content is duplicated. Learning paths reuse
// this model via `kind='learning_path'` + `isOfficial=true`.

model StudyCollection {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String    @map("owner_id") @db.Uuid
  title       String
  description String    @default("")
  // collection | exam_prep | revision | semester | learning_path
  kind        String    @default("collection")
  // true = curated learning path authored by a lecturer/admin (6d).
  isOfficial  Boolean   @default(false) @map("is_official")
  // Optional scoping (semester folders, official course paths).
  courseId    String?   @map("course_id") @db.Uuid
  // Subject — reuses the existing Category taxonomy (Phase 1 metadata).
  categoryId  String?   @map("category_id") @db.Uuid
  // Optional free-text exam name (e.g. "Calculus Final 2026").
  examName    String?   @map("exam_name")
  // fall | spring | summer (text, matches the document semester convention).
  semester    String?   @map("semester")
  academicYear Int?     @map("academic_year")
  // private | public (default private). Public => discoverable in Prep Hub.
  visibility  String    @default("private")
  // Denormalised ranking signal (followers + items), recomputed on change.
  popularityScore Int   @default(0) @map("popularity_score")
  // ─── Engagement counters (Phase 2) ────────────────────────────
  // Denormalised, maintained transactionally with each engagement
  // event row. Store-only in Phase 2 (ranking consumes them in P3).
  // ratingAverage is derived (ratingSum / ratingCount), never stored.
  likeCount    Int @default(0) @map("like_count")
  ratingCount  Int @default(0) @map("rating_count")
  ratingSum    Int @default(0) @map("rating_sum")
  viewCount    Int @default(0) @map("view_count")
  commentCount Int @default(0) @map("comment_count")
  // ─── Discovery (Phase 3) ──────────────────────────────────────
  // FTS haystack, written ONLY by DB triggers (never by the app).
  // The companion `search_vector tsvector GENERATED … STORED` column +
  // its GIN index are added in raw SQL in the migration and are NOT
  // mapped here (DB-managed; mirrors documents.search_vector).
  searchText    String? @map("search_text")
  // Denormalised save count (= study_collection_followers rows),
  // maintained transactionally on follow/unfollow. Used by ranking SQL
  // so "saves" is a column read, not a per-row subquery.
  followerCount Int     @default(0) @map("follower_count")
  // ─── Moderation (Phase 4) ─────────────────────────────────────
  // Reversible "hidden" flag. When set, the collection is removed from
  // every public surface (discovery/search/trending/recommend/public
  // view) but preserved for the owner (shown with a moderator banner).
  // hiddenBy is a plain uuid (no FK, matching parentDocumentId).
  hiddenAt     DateTime? @map("hidden_at") @db.Timestamptz()
  hiddenBy     String?   @map("hidden_by") @db.Uuid
  hiddenReason String?   @map("hidden_reason")
  examDate    DateTime? @map("exam_date") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  owner     User                      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  course    Course?                   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  category  Category?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags      StudyCollectionTag[]
  items     StudyCollectionItem[]
  followers StudyCollectionFollower[]
  likes     StudyCollectionLike[]
  ratings   StudyCollectionRating[]
  views     StudyCollectionView[]
  comments  StudyCollectionComment[]

  @@index([ownerId], map: "study_collections_owner_idx")
  @@index([isOfficial, courseId], map: "study_collections_official_course_idx")
  @@index([visibility, popularityScore(sort: Desc)], map: "study_collections_visibility_popularity_idx")
  @@index([categoryId], map: "study_collections_category_idx")
  @@index([hiddenAt], map: "study_collections_hidden_at_idx")
  @@map("study_collections")
}

// Followers of a (shared/official) collection — drives follower counts,
// the "following" state, and the popularity score (US-55/US-56).
model StudyCollectionFollower {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  collection StudyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId], map: "study_collection_followers_unique")
  @@index([userId], map: "study_collection_followers_user_idx")
  @@map("study_collection_followers")
}

model StudyCollectionTag {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  tagId        String   @map("tag_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  collection StudyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tag        Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([collectionId, tagId], map: "study_collection_tags_unique")
  @@index([tagId], map: "study_collection_tags_tag_idx")
  @@map("study_collection_tags")
}

// ─── Collection engagement (Phase 2) ──────────────────────────────

model StudyCollectionLike {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  collection StudyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId], map: "study_collection_likes_unique")
  @@index([userId], map: "study_collection_likes_user_idx")
  @@map("study_collection_likes")
}

model StudyCollectionRating {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  // 1..5, validated in the service.
  value        Int
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  collection StudyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId], map: "study_collection_ratings_unique")
  @@index([userId], map: "study_collection_ratings_user_idx")
  @@map("study_collection_ratings")
}

model StudyCollectionView {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  viewedAt     DateTime @default(now()) @map("viewed_at") @db.Timestamptz()

  collection StudyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collectionId], map: "study_collection_views_collection_idx")
  @@index([userId, viewedAt], map: "study_collection_views_user_viewed_idx")
  @@map("study_collection_views")
}

model StudyCollectionComment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String    @map("collection_id") @db.Uuid
  authorId     String    @map("author_id") @db.Uuid
  body         String
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  collection StudyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  author     User            @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([collectionId, createdAt], map: "study_collection_comments_collection_created_idx")
  @@index([authorId], map: "study_collection_comments_author_idx")
  @@map("study_collection_comments")
}

model StudyCollectionItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  documentId   String   @map("document_id") @db.Uuid
  // Manual ordering within the collection (drag-to-reorder).
  position     Int      @default(0)
  note         String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  collection StudyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  document   Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([collectionId, documentId], map: "study_collection_items_unique")
  @@index([collectionId, position], map: "study_collection_items_position_idx")
  @@map("study_collection_items")
}

model StudyProgress {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  // reviewing | completed
  status     String   @default("reviewing")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId], map: "study_progress_unique")
  @@index([userId], map: "study_progress_user_idx")
  @@map("study_progress")
}
